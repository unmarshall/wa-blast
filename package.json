{
  "name": "wa-blast",
  "version": "1.0.1",
  "description": "CLI tool to send personalized WhatsApp messages to contacts from a CSV file",
  "type": "module",
  "bin": {
    "wa-blast": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "build:pkg": "npm run build && pkg dist/index.js --targets node18-macos-x64,node18-win-x64,node18-linux-x64 --output binaries/wa-blast --compress GZip"
  },
  "pkg": {
    "assets": [
      "node_modules/@whiskeysockets/baileys/WAProto/**/*",
      "node_modules/@whiskeysockets/baileys/lib/Defaults/baileys-version.json"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.18",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@yao-pkg/pkg": "^5.16.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "whatsapp",
    "cli",
    "messaging",
    "bulk-messaging",
    "automation"
  ],
  "author": "Madhav Bhargava <unmarshall@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unmarshall/wa-blast.git"
  },
  "homepage": "https://github.com/unmarshall/wa-blast#readme",
  "bugs": {
    "url": "https://github.com/unmarshall/wa-blast/issues"
  }
}
